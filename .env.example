# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# --- Local development (SQLite) ---
# Prisma schema: prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# --- Production (PostgreSQL) ---
# Prisma schema: prisma/postgres/schema.prisma
# Run migrations with: npm run db:migrate:prod
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth secret — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-string"

# OAuth provider (optional — only needed if using Google/GitHub login)
# GITHUB_ID=""
# GITHUB_SECRET=""

# OpenRouter API key — required for the "Review with AI" feature
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=""
