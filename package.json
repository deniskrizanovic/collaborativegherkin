{
  "name": "collaborativegherkin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:ws": "node y-websocket-server.mjs",
    "dev:all": "run-p dev dev:ws",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:all": "run-p \"test -- --run\" test:e2e",
    "seed": "npx tsx prisma/seed.ts",
    "db:generate:postgres": "prisma generate --config prisma/postgres/prisma.config.ts",
    "db:migrate:dev:postgres": "prisma migrate dev --config prisma/postgres/prisma.config.ts && prisma generate --config prisma/postgres/prisma.config.ts",
    "db:migrate:prod": "prisma migrate deploy --config prisma/postgres/prisma.config.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@fontsource/public-sans": "^5.2.7",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/core": "^2.10.4",
    "@tiptap/extension-collaboration": "^2.10.4",
    "@tiptap/extension-collaboration-cursor": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "dotenv": "^17.4.2",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.31",
    "nsw-design-system": "^3.24.9",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prisma": "^7.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.20.1"
  }
}
