# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# SQLite database file path (for local development)
# When moving to production, swap this for a PostgreSQL connection string:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DATABASE_URL="file:./dev.db"

# NextAuth secret — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-string"

# OAuth provider (optional — only needed if using Google/GitHub login)
# GITHUB_ID=""
# GITHUB_SECRET=""

# OpenRouter API key — required for the "Review with AI" feature
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=""
