# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/collaborativegherkin"

# NextAuth secret — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-string"

# OAuth provider (optional — only needed if using Google/GitHub login)
# GITHUB_ID=""
# GITHUB_SECRET=""
